{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "SESSION_SECURE_COOKIE": "true",
    "SESSION_SAME_SITE": "none",
    "CACHE_DRIVER": "array",
    "CACHE_STORE": "array",
    "QUEUE_CONNECTION": "sync",
    "DB_CONNECTION": "pgsql",
    "DB_SSLMODE": "require"
  }
}
